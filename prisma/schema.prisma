generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StockMovementType {
  IN
  OUT
}

enum OrderStatus {
  PENDING
  AWAITING_VERIFICATION
  VERIFIED
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum VerificationStatus {
  PENDING
  CONFIRMED
  REJECTED
}

model User {
  id    String  @id @default(uuid())
  name  String
  email String  @unique
  phone String?

  roles String[]

  updatedAt DateTime  @updatedAt
  createdAt DateTime  @default(now())
  lastLogin DateTime?
  isActive  Boolean   @default(true)

  extras Json?

  orders               Order[]
  affiliates           AffiliateLink[]
  earnings             VendorEarning[]
  verifications        CODVerification[]   @relation("AdminVerification")
  stockMovements       StockMovement[]
  addresses            Address[]
  withdrawalRequests   WithdrawalRequest[]
  processedWithdrawals WithdrawalRequest[] @relation("AdminWithdrawal")

  @@index([email])
  @@map("tbl_users")
}

model Address {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  addressType    String // 'shipping', 'billing'
  street_address String?
  city           String
  state          String?
  postal_code    String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([userId])
  @@map("tbl_addresses")
}

model OtpCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@map("tbl_otp_codes")
}

model Product {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String?
  price       Float
  images      String[] // Array of image URLs

  totalStock Int @default(0)

  status String

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  movements  StockMovement[]
  orderItems OrderItem[]
  affiliates AffiliateLink[]

  @@index([slug])
  @@map("tbl_products")
}

model StockMovement {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  type     StockMovementType
  quantity Int

  reason  String
  orderId String?
  userId  String?

  order Order?  @relation(fields: [orderId], references: [id])
  user  User?   @relation(fields: [userId], references: [id])
  notes String?

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([orderId])
  @@index([userId])
  @@index([createdAt])
  @@map("tbl_stock_movements")
}

model AffiliateLink {
  id   String @id @default(uuid())
  code String @unique

  vendorId String
  vendor   User   @relation(fields: [vendorId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  discountType  String
  discountValue Float

  commissionType  String
  commissionValue Float

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  orders         Order[]
  vendorEarnings VendorEarning[]

  @@index([code])
  @@index([vendorId])
  @@index([productId])
  @@map("tbl_affiliate_links")
}

model Order {
  id     String  @id @default(uuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  orderNumber String      @unique
  status      OrderStatus

  affiliateId String?
  affiliate   AffiliateLink? @relation(fields: [affiliateId], references: [id])

  subtotal       Float
  taxAmount      Float
  shippingAmount Float
  discountAmount Float
  totalAmount    Float

  currency String @default("NPR")

  shippingAddressId String?
  billingAddressId  String?
  paymentMethod     String

  notes          String?
  additionalInfo Json? // For any extra details like delivery instructions, etc.

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  createdBy String?

  items          OrderItem[]
  payment        Payment?
  verification   CODVerification?
  earnings       VendorEarning[]
  stockMovements StockMovement[]

  @@index([userId])
  @@index([affiliateId])
  @@index([status])
  @@map("tbl_orders")
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity   Int
  unitPrice  Float
  totalPrice Float

  @@map("tbl_order_items")
}

model Payment {
  id      String @id @default(uuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  paymentMethod String // 'credit_card', 'paypal', 'stripe', 'bank_transfer'
  provider      String

  amount   Float
  currency String @default("NPR")

  transactionId String?

  status PaymentStatus
  paidAt DateTime?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("tbl_payments")
}

model CODVerification {
  id String @id @default(uuid())

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  verifiedBy String
  admin      User   @relation("AdminVerification", fields: [verifiedBy], references: [id])

  verificationStatus VerificationStatus
  customerResponse   String

  remarks String?

  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([orderId])
  @@index([verifiedBy])
  @@map("tbl_cod_verifications")
}

model VendorEarning {
  id String @id @default(uuid())

  vendorId String
  vendor   User   @relation(fields: [vendorId], references: [id])

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  affiliateId String
  affiliate   AffiliateLink @relation(fields: [affiliateId], references: [id])

  commission Float
  currency   String @default("NPR")

  createdAt DateTime @default(now())

  @@index([vendorId])
  @@index([orderId])
  @@index([affiliateId])
  @@map("tbl_vendor_earnings")
}

model WithdrawalRequest {
  id String @id @default(uuid())

  vendorId String
  vendor   User   @relation(fields: [vendorId], references: [id])

  amount   Float
  currency String @default("NPR")

  status String // 'PENDING', 'APPROVED', 'REJECTED'

  remarks          String?
  transactionProof String? // URL or reference to the transaction proof
  requestedAt      DateTime  @default(now())
  processedAt      DateTime?
  rejectionReason  String?

  processedBy String?
  admin       User?   @relation("AdminWithdrawal", fields: [processedBy], references: [id])

  @@index([vendorId])
  @@index([status])
  @@map("tbl_withdrawal_requests")
}
